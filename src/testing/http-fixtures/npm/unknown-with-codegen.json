{
  "name": "my-rn-codegen-package",
  "version": "1.0.0",
  "description": "A package with codegen config",
  "deprecated": false,
  "codegenConfig": {
    "name": "mycodegen",
    "type": "all",
    "jsSrcsDir": "./src/specs",
